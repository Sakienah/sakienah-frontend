# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Maintenance mode — zet op 'true' om de webshop af te schermen voor bezoekers
# Bezoekers zien alleen /dropping-soon. Developers bypassen via ?bypass=<DEV_BYPASS_SECRET> op /dropping-soon
MAINTENANCE_MODE=false

# Developer bypass secret — gebruik een sterke, random string
# Local: mag een simpele string zijn (bijv. sakienah-dev-bypass-2024)
# Productie (Vercel): gebruik een andere, sterke string (bijv. lqbEMSVJLcl21QkheMgCubX8JCfpaqWe)
DEV_BYPASS_SECRET=
